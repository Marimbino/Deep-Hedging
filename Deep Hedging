0]\n","lev_lags = np.arange(-10, 11)\n","\n","for ticker, color in zip(comp_tickers, colors):\n","    leverage_vals = []\n","    for l in lev_lags:\n","        leverage_vals.append(log_returns[ticker].corr(log_returns[ticker].abs().shift(-l)))\n","    ax5.plot(lev_lags, leverage_vals, marker='^', markersize=4, linewidth=1.5, color=color, label=ticker)\n","\n","ax5.axhline(0, color='black', linestyle='-', linewidth=0.8)\n","ax5.axvline(0, color='gray', linestyle=':', linewidth=1)\n","ax5.set_title('5. Leverage Effect: $Corr(R_t, |R_{t+\\\\tau}|)$ Across Sectors', fontweight='bold')\n","ax5.set_xlabel('Lag $\\\\tau$ (Days) [Positive $\\\\tau$ = Future Volatility]')\n","ax5.set_ylabel('Correlation Coefficient')\n","ax5.set_xticks(np.arange(-10, 11, 2))\n","ax5.axvspan(1, 10, color='yellow', alpha=0.08, label='Asymmetric Volatility Impact')\n","ax5.legend(loc='lower left')\n","\n","\n","# SUBPLOT 6: cross-correlation matrix\n","ax6 = axes[2, 1]\n","corr_matrix = log_returns.corr()\n","sns.heatmap(corr_matrix, annot=True, cmap='coolwarm', fmt=\".2f\", linewidths=.4,\n","            ax=ax6, cbar_kws={'label': 'Correlation Coefficient'}, annot_kws={\"size\": 9})\n","ax6.set_title('6. Complete Asset Basket Cross-Correlation Matrix', fontweight='bold')\n","\n","\n","# show\n","plt.suptitle('Comparative Exploratory Data Analysis', fontweight='bold')\n","plt.tight_layout()\n","plt.show()\n","\n","\n","# descriptive statistics\n","stats_list = []\n","for col in log_returns.columns:\n","    col_data = log_returns[col]\n","    stats_list.append({\n","        'Asset Ticker': col,\n","        'Mean (μ)': f\"{col_data.mean():.6f}\",\n","        'Std Dev (σ)': f\"{col_data.std():.5f}\",\n","        'Skewness': f\"{skew(col_data):.3f}\",\n","        'Excess Kurtosis': f\"{kurtosis(col_data, fisher=True):.3f}\"\n","    })\n","df_stats = pd.DataFrame(stats_list)\n","print(\"\\n\" + \"=\"*80)\n","print(\"Descriptive Statistics Summary\")\n","print(\"=\"*80)\n","print(df_stats.to_markdown(index=False))\n","print(\"=\"*80)"],"metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-03T17:35:14.373557Z","iopub.execute_input":"2026-06-03T17:35:14.374218Z","iopub.status.idle":"2026-06-03T17:35:16.86909Z","shell.execute_reply.started":"2026-06-03T17:35:14.374186Z","shell.execute_reply":"2026-06-03T17:35:16.868155Z"},"id":"uUGMusoPlWqE","executionInfo":{"status":"ok","timestamp":1780522181918,"user_tz":-120,"elapsed":6865,"user":{"displayName":"Riccardo Ravelli","userId":"15250967032132411123"}},"outputId":"2f6762ef-34ed-4640-98ba-35686fd07af9","colab":{"base_uri":"https://localhost:8080/","height":1000}},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1500x1600 with 7 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","================================================================================\n","Descriptive Statistics Summary\n","================================================================================\n","| Asset Ticker   |   Mean (μ) |   Std Dev (σ) |   Skewness |   Excess Kurtosis |\n","|:---------------|-----------:|--------------:|-----------:|------------------:|\n","| DIA            |   0.0003   |       0.01115 |     -0.515 |            13.863 |\n","| EEM            |   0.00012  |       0.01595 |     -0.29  |            12.145 |\n","| IWM            |   0.000261 |       0.01557 |     -0.311 |             8.706 |\n","| QQQ            |   0.000542 |       0.01378 |     -0.53  |             6.141 |\n","| SPY            |   0.000339 |       0.01188 |     -0.621 |            12.447 |\n","| XLE            |   0.000114 |       0.01883 |     -0.748 |            10.929 |\n","| XLF            |   0.000153 |       0.01906 |      0.267 |            20.745 |\n","| XLK            |   0.000523 |       0.01459 |     -0.586 |             8.268 |\n","| XLP            |   0.00024  |       0.00973 |     -1.04  |            20.07  |\n","| XLV            |   0.000316 |       0.01112 |     -0.675 |            12.329 |\n","================================================================================\n"]}],"execution_count":6},{"cell_type":"markdown","source":["## 1 — Entropic Loss\n","\n","**Objective**: minimize the P&L\n","\n","$$\n","(\\delta^{\\theta} \\cdot S)_T - C_T(\\delta^{\\theta}) - Z\n","$$\n","\n","by choosing the best hedging strategy $\\delta^{\\theta}$ with neural networks.\n","\n","The P&L is a random variable and not only a function of the strategy $\\delta^{\\theta}$ (it cannot be directly optimized). This optimization can only be achieved by some scalar $\\rho(-\\text{P&L})$ that focuses only on losses and that satisfies some mathematical properties.\n","\n","A map $\\rho:X \\rightarrow \\mathbb{R}$ is called convex risk measure if it satisfies:\n","\n","*   convexity;\n","*   monotonicity: $x\\ge y ⇒ \\rho(x) \\le \\rho(y),\\ \\ \\ x,y \\in X$;\n","*   translation invariance: $\\rho(x+a)=\\rho(x)-a, \\ \\ \\ \\forall a\\ge 0, \\forall x \\in X$.\n","\n","A possible convex risk measures are the Conditional Value at Risk $\\text{CVaR}_{\\alpha}$ (or Expected Shortfall $\\text{ES}_{\\alpha}$) or the Entropic Loss. We chose the second one.\n"],"metadata":{"id":"JF9b2a4kwVp3"}},{"cell_type":"code","source":["Risk_Aversion = 10\n","\n","# Entropic Loss\n","def entropic_loss(pnl, risk_aversion):\n","\n","  pnl = tf.reshape(tf.cast(pnl, tf.float32), [-1])\n","\n","  # N is the mini-batch dimension\n","  N = tf.cast(tf.size(pnl), tf.float32)\n","\n","  # reduce_logsumexp internally apply the same shifting of the your max_val\n","  log_mean_exp = tf.reduce_logsumexp(-risk_aversion * pnl) - tf.math.log(N)\n","\n","  loss_val = (1.0 / risk_aversion) * log_mean_exp\n","\n","  return loss_val"],"metadata":{"id":"DACiIj2twVp4","trusted":true,"execution":{"iopub.status.busy":"2026-06-03T17:28:10.602752Z","iopub.execute_input":"2026-06-03T17:28:10.602957Z","iopub.status.idle":"2026-06-03T17:28:10.607638Z","shell.execute_reply.started":"2026-06-03T17:28:10.602936Z","shell.execute_reply":"2026-06-03T17:28:10.606905Z"},"executionInfo":{"status":"ok","timestamp":1780522181929,"user_tz":-120,"elapsed":3,"user":{"displayName":"Riccardo Ravelli","userId":"15250967032132411123"}}},"outputs":[],"execution_count":7},{"cell_type":"code","source":["# Shuffle again the 40_448 training paths into 79 batches of 512.\n","# Shared by both the MLP and the GRU training loops.\n","dataset = tf.data.Dataset.from_tensor_slices(train)\n","dataset = dataset.shuffle(buffer_size=40_448).batch(512)\n","\n","# Time-to-maturity grid\n","tau_seq = tf.constant([(num_steps - t) / num_steps for t in range(num_steps)], dtype=tf.float32)"],"metadata":{"id":"Yf_WonlDwVp5","trusted":true,"execution":{"iopub.status.busy":"2026-06-03T17:28:10.608513Z","iopub.execute_input":"2026-06-03T17:28:10.6091Z","iopub.status.idle":"2026-06-03T17:28:12.570052Z","shell.execute_reply.started":"2026-06-03T17:28:10.609076Z","shell.execute_reply":"2026-06-03T17:28:12.569125Z"},"executionInfo":{"status":"ok","timestamp":1780522185542,"user_tz":-120,"elapsed":3611,"user":{"displayName":"Riccardo Ravelli","userId":"15250967032132411123"}}},"outputs":[],"execution_count":8},{"cell_type":"markdown","source":["## 2 — MLP Deep Hedger"],"metadata":{"id":"XW0vocOOwVp5"}},{"cell_type":"markdown","source":["Input shape: `(3, )` = ($\\delta_{t-1}, S_t, \\tau_t$)"],"metadata":{"id":"7D-F2CzowVp6"}},{"cell_type":"code","source":["# reset seeds\n","random.seed(42); np.random.seed(42); tf.random.set_seed(42)\n","\n","def mlp_features(x):\n","    delta_prev = x[:, 0:1]\n","    S          = x[:, 1:2]\n","    tau        = x[:, 2:3]\n","    m = tf.math.log(S / K)\n","    return tf.concat([delta_prev, m, tau], axis=1)\n","\n","hedger_mlp = keras.Sequential([\n","    keras.Input(shape=(3,)),\n","    keras.layers.Lambda(mlp_features),\n","    keras.layers.Dense(32, activation=\"relu\"),\n","    keras.layers.Dense(32, activation=\"relu\"),\n","    keras.layers.Dense(1,