68\n","[GRU] Epoch 42/50 | Entropic Loss: 0.023968 | Mean PnL: -0.020595\n","[GRU] Epoch 43/50 | Entropic Loss: 0.023951 | Mean PnL: -0.020591\n","[GRU] Epoch 44/50 | Entropic Loss: 0.023818 | Mean PnL: -0.020392\n","[GRU] Epoch 45/50 | Entropic Loss: 0.023734 | Mean PnL: -0.020439\n","[GRU] Epoch 46/50 | Entropic Loss: 0.023758 | Mean PnL: -0.020385\n","[GRU] Epoch 47/50 | Entropic Loss: 0.023639 | Mean PnL: -0.020308\n","[GRU] Epoch 48/50 | Entropic Loss: 0.023605 | Mean PnL: -0.020193\n","[GRU] Epoch 49/50 | Entropic Loss: 0.023617 | Mean PnL: -0.020260\n","[GRU] Epoch 50/50 | Entropic Loss: 0.023489 | Mean PnL: -0.020162\n"]}],"execution_count":16},{"cell_type":"markdown","source":["## 4 — Out-of-sample testing and Black-Scholes.\n","\n","$$\n","d_1 = \\frac{\\log(S/K) + (r + \\frac{\\sigma^2}{2})\\cdot \\tau}{\\sigma \\cdot \\sqrt{\\tau}}, \\ \\ \\ \\tau=T-t\n","$$\n","\n","and\n","\n","$$\n","Δ_{call}=\\Phi(d_1)\n","$$\n","\n","where $\\Phi$ is the cumulative standard normal distribution. <br>\n","If you hold on long call option, you short $\\Delta$ shares of the stock to be delta-neutral. As time evolves, $\\Delta$ changes, so you rebalance continuously (in theory) or discreteley (in practice)."],"metadata":{"id":"yDmkJvQjwVp_"}},{"cell_type":"code","source":["S_test = tf.cast(test, tf.float32)\n","n_test = S_test.shape[0]\n","T = S_test.shape[1] - 1\n","\n","r = 0.045   # risk free rate\n","sigma = 0.2   # volatility\n","\n","\n","# bs_delta function to compute Delta\n","def bs_delta(S, K, tau, r, sigma):\n","    tau = np.maximum(tau, 1e-5)   # otherwise error with np.sqrt(tau)\n","    d1 = (np.log(S / K) + (r + 0.5 * sigma**2) * tau) / (sigma * np.sqrt(tau))\n","    return norm.cdf(d1)\n","\n","payoff = tf.maximum(S_test[:, -1:] - K, 0.0)\n","\n","\n","# MLP hedger (sequential: delta feeds back into the input)\n","pnl_mlp   = tf.zeros((n_test, 1))\n","delta_mlp = tf.zeros((n_test, 1))\n","for t in range(T):\n","    S_today = S_test[:, t:t+1]\n","    tau_t = tf.fill((n_test, 1), (num_steps - t) / num_steps)\n","    state = tf.concat([delta_mlp, S_today, tau_t], axis=1)\n","    new_delta = hedger_mlp(state, training=False)\n","    tcost = tf.abs(new_delta - delta_mlp) * S_today * brokerage_fee\n","    price_change = S_test[:, t+1:t+2] - S_today\n","    pnl_mlp += (new_delta * price_change) - tcost\n","    delta_mlp = new_delta\n","pnl_mlp -= payoff\n","pnl_mlp_flat = pnl_mlp.numpy().flatten()\n","\n","\n","# GRU hedger (vectorised, no loop)\n","S_seq = S_test[:, :num_steps]\n","tau = tf.broadcast_to(tau_seq, tf.shape(S_seq))\n","inputs = tf.stack([S_seq, tau], axis=-1)\n","delta_gru = hedger_gru(inputs, training=False)[:, :, 0]\n","delta_gru_prev = tf.concat([tf.zeros((n_test, 1)), delta_gru[:, :-1]], axis=1)\n","pc_gru = S_test[:, 1:num_steps+1] - S_seq\n","tc_gru = tf.abs(delta_gru - delta_gru_prev) * S_seq * brokerage_fee\n","pnl_gru = tf.reduce_sum(delta_gru * pc_gru - tc_gru, axis=1, keepdims=True) - payoff\n","pnl_gru_flat = pnl_gru.numpy().flatten()\n","\n","\n","# Black-Scholes (vectorised, computed once)\n","S_np = S_test.numpy()[:, :T]\n","tau_bs= np.array([(T - t) / 252.0 for t in range(T)])[np.newaxis, :]\n","delta_bs = bs_delta(S_np, K, tau_bs, r, sigma)\n","delta_bs_prev = np.hstack([np.zeros((n_test, 1)), delta_bs[:, :-1]])\n","pc_bs = S_test.numpy()[:, 1:T+1] - S_np\n","tc_bs = np.abs(delta_bs - delta_bs_prev) * S_np * brokerage_fee\n","pnl_bs = np.sum(delta_bs * pc_bs - tc_bs, axis=1, keepdims=True) - payoff.numpy()\n","pnl_bs_flat = pnl_bs.flatten()\n","\n","\n","print(\"======================== OUT-OF-SAMPLE RESULTS ========================\")\n","print(f\"MLP HEDGER    | Mean PnL: {np.mean(pnl_mlp_flat):.4f} | Entropic Loss: {entropic_loss(pnl_mlp_flat,Risk_Aversion):.4f} | std: {np.std(pnl_mlp_flat):.4f}\")\n","print(f\"GRU HEDGER    | Mean PnL: {np.mean(pnl_gru_flat):.4f} | Entropic Loss: {entropic_loss(pnl_gru_flat,Risk_Aversion):.4f} | std: {np.std(pnl_gru_flat):.4f}\")\n","print(f\"BLACK-SCHOLES | Mean PnL: {np.mean(pnl_bs_flat):.4f} | Entropic Loss: {entropic_loss(pnl_bs_flat,Risk_Aversion):.4f} | std: {np.std(pnl_bs_flat):.4f}\")\n","print(\"=======================================================================\")\n","\n","\n","# MLP vs GRU vs Black-Scholes\n","plt.figure(figsize=(12, 6))\n","plt.hist(pnl_bs_flat,  bins=100, alpha=0.5, label='Black-Scholes', color='red',   density=True)\n","plt.hist(pnl_mlp_flat, bins=100, alpha=0.5, label='MLP Hedger',    color='blue',  density=True)\n","plt.hist(pnl_gru_flat, bins=100, alpha=0.5, label='GRU Hedger',    color='green', density=True)\n","plt.axvline(np.mean(pnl_bs_flat),  color='red',   linestyle='dashed', linewidth=1.5)\n","plt.axvline(np.mean(pnl_mlp_flat), color='blue',  linestyle='dashed', linewidth=1.5)\n","plt.axvline(np.mean(pnl_gru_flat), color='green', linestyle='dashed', linewidth=1.5)\n","plt.title('P&L Distribution at Maturity', fontsize=14)\n","plt.xlabel('Final P&L', fontsize=12)\n","plt.ylabel('Frequency (Density)', fontsize=12)\n","plt.legend(fontsize=12)\n","plt.grid(True, alpha=0.3)\n","plt.show()"],"metadata":{"id":"BuSKJLo6wVp_","trusted":true,"execution":{"iopub.status.busy":"2026-06-03T17:29:46.043696Z","iopub.execute_input":"2026-06-03T17:29:46.044036Z","iopub.status.idle":"2026-06-03T17:29:47.126448Z","shell.execute_reply.started":"2026-06-03T17:29:46.04401Z","shell.execute_reply":"2026-06-03T17:29:47.125595Z"},"colab":{"base_uri":"https://localhost:8080/","height":665},"executionInfo":{"status":"ok","timestamp":1780522320137,"user_tz":-120,"elapsed":933,"user":{"displayName":"Riccardo Ravelli","userId":"15250967032132411123"}},"outputId":"8b2c3c39-8377-43b7-bd87-38233f782da5"},"outputs":[{"output_type":"stream","name":"stdout","text":["======================== OUT-OF-SAMPLE RESULTS ========================\n","MLP HEDGER    | Mean PnL: -0.0233 | Entropic Loss: 0.0248 | std: 0.0162\n","GRU HEDGER    | Mean PnL: -0.0218 | Entropic Loss: 0.0249 | std: 0.0225\n","BLACK-SCHOLES | Mean