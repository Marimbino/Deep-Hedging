re>\n"]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["\u001b[1m Total params: \u001b[0m\u001b[38;5;34m3,489\u001b[0m (13.63 KB)\n"],"text/html":["<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\"> Total params: </span><span style=\"color: #00af00; text-decoration-color: #00af00\">3,489</span> (13.63 KB)\n","</pre>\n"]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["\u001b[1m Trainable params: \u001b[0m\u001b[38;5;34m3,489\u001b[0m (13.63 KB)\n"],"text/html":["<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\"> Trainable params: </span><span style=\"color: #00af00; text-decoration-color: #00af00\">3,489</span> (13.63 KB)\n","</pre>\n"]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["\u001b[1m Non-trainable params: \u001b[0m\u001b[38;5;34m0\u001b[0m (0.00 B)\n"],"text/html":["<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\"> Non-trainable params: </span><span style=\"color: #00af00; text-decoration-color: #00af00\">0</span> (0.00 B)\n","</pre>\n"]},"metadata":{}}],"execution_count":14},{"cell_type":"markdown","source":["We need to evaluate the hedger at maturity, so we build a function. <br>\n","A single GRU processes the full path in one shot (`return_sequences=True`): it takes the price and time-to-maturity at every step as a `(batch, 30, 2)` tensor, produces a delta at every step as a `(batch, 30, 1)` tensor, and the P&L is then computed in one vectorised operation."],"metadata":{"id":"MX6p-5URwVp-"}},{"cell_type":"code","source":["# TensorFlow computation graph\n","@tf.function\n","\n","def train_step_gru(Batch):\n","\n","    # build the (batch, num_steps, 2) input tensor: [S_t, tau_t]\n","    S_seq  = Batch[:, :num_steps]\n","    tau    = tf.broadcast_to(tau_seq, tf.shape(S_seq))\n","    inputs = tf.stack([S_seq, tau], axis=-1)\n","\n","    # automatic differentiation\n","    with tf.GradientTape() as tape:\n","\n","        # single GRU forward pass -> delta at every time step\n","        delta_seq  = hedger_gru(inputs, training=True)[:, :, 0]\n","\n","        # previous delta: 0 at t=0, then the shifted sequence\n","        delta_prev = tf.concat([tf.zeros((tf.shape(Batch)[0], 1)), delta_seq[:, :-1]], axis=1)\n","\n","        # vectorised P&L  no loop\n","        price_changes = Batch[:, 1:] - S_seq\n","        transaction_costs = tf.abs(delta_seq - delta_prev) * S_seq * brokerage_fee\n","        pnl = tf.reduce_sum(delta_seq * price_changes - transaction_costs, axis=1, keepdims=True)\n","\n","        # payoff subtraction at maturity\n","        pnl -= tf.maximum(Batch[:, -1:] - K, 0.0)\n","\n","        # entropic loss\n","        loss = entropic_loss(pnl, Risk_Aversion)\n","\n","    # Backpropagation Through Time + optimization step\n","    gradients = tape.gradient(loss, hedger_gru.trainable_variables)\n","    optimizer_gru.apply_gradients(zip(gradients, hedger_gru.trainable_variables))\n","\n","    return loss, tf.reduce_mean(pnl)"],"metadata":{"id":"NmauFKqzwVp-","trusted":true,"execution":{"iopub.status.busy":"2026-06-03T17:29:17.618089Z","iopub.execute_input":"2026-06-03T17:29:17.61841Z","iopub.status.idle":"2026-06-03T17:29:17.626983Z","shell.execute_reply.started":"2026-06-03T17:29:17.618353Z","shell.execute_reply":"2026-06-03T17:29:17.626212Z"},"executionInfo":{"status":"ok","timestamp":1780522284690,"user_tz":-120,"elapsed":5,"user":{"displayName":"Riccardo Ravelli","userId":"15250967032132411123"}}},"outputs":[],"execution_count":15},{"cell_type":"markdown","source":["50 epochs. In each epoch all 79 batches of 512 paths."],"metadata":{"id":"Qvd3jhsAwVp_"}},{"cell_type":"code","source":["for epoc