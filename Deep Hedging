tate, training=True)\n","            trade = new_delta - delta\n","\n","            # 4) costs, gains and pnl\n","            transaction_costs = tf.abs(trade) * S_t * brokerage_fee\n","            price_change = Batch[:, t+1:t+2] - S_t\n","            pnl += (new_delta * price_change) - transaction_costs\n","\n","            # 5) update delta\n","            delta = new_delta\n","\n","        # payoff subtraction at maturity\n","        payoff = tf.maximum(Batch[:, -1:] - K, 0.0)\n","        pnl -= payoff\n","\n","        # entropic loss\n","        loss = entropic_loss(pnl, Risk_Aversion)\n","\n","    # Backpropagation Through Time + optimization step\n","    gradients = tape.gradient(loss, hedger_mlp.trainable_variables)\n","    optimizer_mlp.apply_gradients(zip(gradients, hedger_mlp.trainable_variables))\n","\n","    return loss, tf.reduce_mean(pnl)"],"metadata":{"id":"4MeZh6eRwVp8","trusted":true,"execution":{"iopub.status.busy":"2026-06-03T17:28:13.388717Z","iopub.execute_input":"2026-06-03T17:28:13.389188Z","iopub.status.idle":"2026-06-03T17:28:13.396529Z","shell.execute_reply.started":"2026-06-03T17:28:13.389151Z","shell.execute_reply":"2026-06-03T17:28:13.395603Z"},"executionInfo":{"status":"ok","timestamp":1780522187771,"user_tz":-120,"elapsed":16,"user":{"displayName":"Riccardo Ravelli","userId":"15250967032132411123"}}},"outputs":[],"execution_count":11},{"cell_type":"markdown","source":["50 epochs. In each epoch all 79 batches of 512 paths."],"metadata":{"id":"o3amDfj2wVp8"}},{"cell_type":"code","source":["for epoch in range(50):\n","\n","    epoch_loss_avg = tf.keras.metrics.Mean()\n","    epoch_pnl_avg = tf.keras.metrics.Mean()\n","\n","    for batch in dataset:\n","        Batch = tf.cast(batch, tf.float32)\n","        batch_loss, batch_pnl = train_step_mlp(Batch)\n","        epoch_loss_avg.update_state(batch_loss)\n","        epoch_pnl_avg.update_state(batch_pnl)\n","\n","    print(f\"[MLP] Epoch {epoch+1}/50 | Entropic Loss: {epoch_loss_avg.result(