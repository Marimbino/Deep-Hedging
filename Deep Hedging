137        0.5909\n","  23         0.6927         0.8081        0.5938\n","  24         0.6924         0.8040        0.5975\n","  25         0.6922         0.8006        0.6005\n","  26         0.6919         0.7981        0.6045\n","  27         0.6918         0.7954        0.6091\n","  28         0.6911         0.7917        0.6138\n","  29         0.6905         0.7856        0.6183\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}],"execution_count":21},{"cell_type":"markdown","source":["## 6 — Performance varying parameters\n","\n","So far we trained the hedgers once. Here we re-train the MLP and the GRU while changing one parameter at a time — the transaction cost, the risk aversion $\\lambda$ and the maturity — and we compare them with Black-Scholes.\n","\n","Since we now re-train many times, we use fewer epochs.\n"],"metadata":{"id":"wq8u0KrslWqN"}},{"cell_type":"code","source":["# fewer epochs\n","sweep_epochs = 10\n","\n","def reset_seeds(seed=42):\n","    random.seed(seed)\n","    np.random.seed(seed)\n","    tf.random.set_seed(seed)"],"metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-03T17:29:48.361728Z","iopub.execute_input":"2026-06-03T17:29:48.362051Z","iopub.status.idle":"2026-06-03T17:29:48.366839Z","shell.execute_reply.started":"2026-06-03T17:29:48.362012Z","shell.execute_reply":"2026-06-03T17:29:48.366045Z"},"id":"x_FFwRUwlWqN","executionInfo":{"status":"ok","timestamp":1780522321865,"user_tz":-120,"elapsed":4,"user":{"displayName":"Riccardo Ravelli","userId":"15250967032132411123"}}},"outputs":[],"execution_count":22},{"cell_type":"code","source":["# Same window construction as Part 0, but with a variable number of steps,\n","# so we can rebuild the data for different maturities.\n","def build_trajectories(n_steps):\n","\n","    # n_steps + 1 = n_steps trading steps + the initial price\n","    window_size = n_steps + 1\n","    trajectories = []\n","\n","    # slide a window along every ticker series\n","    for ticker_idx in range(data_np.shape[1]):\n","\n","        # drop missing values (tickers that start later, skipped days)\n","        series = data_np[:, ticker_idx]\n","        series = series[~np.isnan(series)]\n","\n","        # slide by one day, normalize by the first price of the window\n","        for d in range(0, len(series) - window_size + 1):\n","            window = series[d : d + window_size]\n","            trajectories.append(window / window[0])\n","\n","    trajectories = np.array(trajectories, dtype=\"float32\")\n","\n","    # 80% train, with a gap in between to avoid data leakage\n","    traj_train = np.concatenate([trajectories[0:4096],\n","                            trajectories[5000:9096],\n","                            trajectories[10000:14096],\n","                            trajectories[15000:19096],\n","                            trajectories[20000:24096],\n","                            trajectories[25000:29096],\n","                            trajectories[30000:34096],\n","                            trajectories[35000:39096],\n","                            trajectories[40000:44096],\n","                            trajectories[45000:49096]])\n","    traj_test = np.concatenate([trajectories[4127:5000],\n","                           trajectories[9127:10000],\n","                           trajectories[14127:15000],\n","                           trajectories[19127:20000],\n","                           trajectories[24127:25000],\n","                           trajectories[29127:30000],\n","                           trajectories[34127:35000],\n","                           trajectories[39127:40000],\n","                           trajectories[44127:45000],\n","                           trajectories[49127:50000]])\n","\n","    # shuffle to mix the market regimes\n","    np.random.shuffle(traj_train)\n","    np.random.shuffle(traj_test)\n","\n","    return traj_train, traj_test"],"metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-03T17:29:48.367734Z","iopub.execute_input":"2026-06-03T17:29:48.368111Z","iopub.status.idle":"2026-06-03T17:29:48.382302Z","shell.execute_reply.started":"2026-06-03T17:29:48.368086Z","shell.execute_reply":"2026-06-03T17:29:48.381439Z"},"id":"kWSn39jMlWqN","executionInfo":{"status":"ok","timestamp":1780522321874,"user_tz":-120,"elapsed":4,"user":{"displayName":"Riccardo Ravelli","userId":"15250967032132411123"}}},"outputs":[],"execution_count":23},{"cell_type":"markdown","source":["### 6.1 — Training functions\n","\n","MLP and GRU training loops from Parts 1 and 2 wrapped into function so they can be called different times for the .\n"],"metadata":{"id":"V1Rw08iGlWqP"}},{"cell_type":"code","source":["def mlp_features(x):\n","        delta_prev = x[:, 0:1]\n","        S          = x[:, 1:2]\n","        tau        = x[:, 2:3]\n","        m = tf.math.log(S / K)\n","        return tf.concat([delta_prev, m, tau], axis=1)\n","\n","def train_mlp(train_data, n_steps, K, fee, risk_aversion, epochs=sweep_epochs):\n","\n","    # same network as Part 1\n","    reset_seeds()\n","\n","    hedger = keras.Sequential([\n","        keras.Input(shape=(3,)),\n","        keras.layers.Lambda(mlp_features),\n","        keras.layers.Dense(32, activation=\"relu\"),\n","        keras.layers.Dense(32, activation=\"relu\"),\n","        keras.layers.Dense(1, activation=\"sigmoid\")\n","    ])\n","    optimizer = keras.optimizers.Adam(learning_rate=0.001)\n","\n","    dataset = tf.data.Dataset.from_tensor_slices(train_data)\n","    dataset = dataset.shuffle(len(train_data)).batch(512, drop_remainder=True)\n","\n","    @tf.function\n","    def train_step(Batch):\n","\n","        delta = tf.zeros((512, 1))\n","        pnl = tf.zeros((512, 1))\n","\n","        with tf.GradientTape() as tape:\n","\n","            # iteration over the trading days\n","            for t in range(n_steps):\n","\n","                # price and market state at time t\n","                S_t = Batch[:, t:t+1]\n","                tau_t = tf.fill((512, 1), (n_steps - t) / n_steps)\n","                state = tf.concat([delta, S_t, tau_t], axis=1)\n","\n","                # new delta, costs and pnl\n","                new_delta = hedger(state, training=True)\n","                transaction_costs = tf.abs(new_delta - delta) * S_t * fee\n","                price_change = Batch[:, t+1:t+2] - S_t\n","                pnl += (new_delta * price_change) - transaction_costs\n","                delta = new_delta\n","\n","            # payoff subtraction at maturity and entropic loss\n","            pnl -= tf.maximum(Batch[:, -1:] - K, 0.0)\n","            loss = entropic_loss(pnl, risk_aversion)\n","\n","        gradients = tape.gradient(loss, hedger.trainable_variables)\n","        optimizer.apply_gradients(zip(gradients, hedger.trainable_variables))\n","        return loss\n","\n","    for epoch in range(epochs):\n","        for batch in dataset:\n","            train_step(tf.cast(batch, tf.float32))\n","\n","    return hedger"],"metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-03T17:29:48.383997Z","iopub.execute_input":"2026-06-03T17:29:48.38433Z","iopub.status.idle":"2026-06-03T17:29:48.402475Z","shell.execute_reply.started":"2026-06-03T17:29:48.384289Z","shell.execute_reply":"2026-06-03T17:29:48.401846Z"},"id":"cuxMLInZlWqP","executionInfo":{"status":"ok","timestamp":1780522321899,"user_tz":-120,"elapsed":21,"user":{"displayName":"Riccardo Ravelli","userId":"15250967032132411123"}}},"outputs":[],"execution_count":24},{"cell_type":"code","source":["def gru_features(x):\n","        S   = x[..., 0:1]\n","        tau = x[..., 1:2]\n","        m = tf.math.log(S / K)\n","        return tf.concat([m, tau], axis=-1)\n","\n","def train_gru(train_data, n_steps, K, fee, risk_aversion, epochs=sweep_epochs, gru_units=32):\n","\n","    # same network as Part 2\n","    reset_seeds()\n","    hedger = keras.Sequential([\n","        keras.Input(shape=(n_steps, 2)),\n","        keras.layers.Lambda(gru_features),\n","        keras.layers.GRU(gru_units, return_sequences=True),\n","        keras.layers.Dense(1, activation=\"sigmoid\")\n","    ])\n","    optimizer = keras.optimizers.Adam(learning_rate=0.001)\n","\n","    # time-to-maturity grid\n","    tau_grid = tf.constant([(n_steps - t) / n_steps for t in range(n_steps)], dtype=tf.float32)\n","\n","    dataset = tf.data.Dataset.from_tensor_slices(train_data)\n","    dataset = dataset.shuffle(len(train_data)).batch(512, drop_remainder=True)\n","\n","    @tf.function\n","    def train_step(Batch):\n","\n","        # build the (batch, n_steps, 2) input tensor: [S_t, tau_t]\n","        S_seq  = Batch[:, :n_steps]\n","        tau    = tf.broadcast_to(tau_grid, tf.shape(S_seq))\n","        inputs = tf.stack([S_seq, tau], axis=-1)\n","\n","        with tf.GradientTape() as tape:\n","\n","            # single GRU forward pass -> delta at every time step\n","            delta_seq  = hedger(inputs, training=True)[:, :, 0]\n","            delta_prev = tf.concat([tf.zeros((512, 1)), delta_seq[:, :-1]], axis=1)\n","\n","            # vectorised P&L, no loop\n","            price_changes = Batch[:, 1:] - S_seq\n","            transaction_costs = tf.abs(delta_seq - delta_prev) * S_seq * fee\n","            pnl = tf.reduce_sum(delta_seq * price_changes - transaction_costs, axis=1, keepdims=True)\n","\n","            # payoff subtraction at maturity and entropic loss\n","            pnl -= tf.maximum(Batch[:, -1:] - K, 0.0)\n","            loss = entropic_loss(pnl, risk_aversion)\n","\n","        gradients = tape.gradient(loss, hedger.trainable_variables)\n","        optimizer.apply_gradients(zip(gradients, hedger.trainable_variables))\n","        return loss\n","\n","    for epoch in range(epochs):\n","        for batch in dataset:\n","            train_step(tf.cast(batch, tf.float32))\n","\n","    return hedger"],"metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-03T17:29:48.403705Z","iopub.execute_input":"2026-06-03T17:29:48.404048Z","iopub.status.idle":"2026-06-03T17:29:48.419749Z","shell.execute_reply.started":"2026-06-03T17:29:48.404024Z","shell.execute_reply":"2026-06-03T17:29:48.418956Z"},"id":"4G6VsJxIlWqQ","executionInfo":{"status":"ok","timestamp":1780522321926,"user_tz":-120,"elapsed":23,"user":{"displayName":"Riccardo Ravelli","userId":"15250967032132411123"}}},"outputs":[],"execution_count":25},{"cell_type":"markdown","source":["### 6.2 — Out-of-sample evaluation\n","\n","The same out-of-sample P&L computation of the testing section, written as functions so we can score the three hedgers (MLP, GRU, Black-Scholes) on any test set.\n","\n","`metrics` collects the numbers we look at: mean and standard deviation of the P&L, the entropic loss, the 95% Expected Shortfall (CVaR — a positive number is a loss) and the turnover, i.e. the total amount traded.\n"],"metadata":{"id":"q0H4fd4ilWqQ"}},{"cell_type":"code","source":["# MLP P&L: sequential, delta feeds back into the input\n","def pnl_mlp(hedger, test_data, n_steps, K, fee):\n","    n = test_data.shape[0]\n","    S = tf.cast(test_data, tf.float32)\n","\n","    delta = tf.zeros((n, 1))\n","    pnl = tf.zeros((n, 1))\n","    deltas = []\n","\n","    for t in range(n_steps):\n","        S_t = S[:, t:t+1]\n","        tau_t = tf.fill((n, 1), (n_steps - t) / n_steps)\n","        new_delta = hedger(tf.concat([delta, S_t, tau_t], axis=1), training=False)\n","        pnl += new_delta * (S[:, t+1:t+2] - S_t) - tf.abs(new_delta - delta) * S_t * fee\n","        delta = new_delta\n","        deltas.append(new_delta.numpy().flatten())\n","\n","    pnl -= tf.maximum(S[:, -1:] - K, 0.0)\n","    return pnl.numpy().flatten(), np.array(deltas).T\n","\n","\n","# GRU P&L: one forward pass over the whole path\n","def pnl_gru(hedger, test_data, n_steps, K, fee):\n","    n = test_data.shape[0]\n","    S = tf.cast(test_data, tf.float32)\n","    tau_grid = tf.constant([(n_steps - t) / n_steps for t in range(n_steps)], dtype=tf.float32)\n","\n","    S_seq = S[:, :n_steps]\n","    inputs = tf.stack([S_seq, tf.broadcast_to(tau_grid, tf.shape(S_seq))], axis=-1)\n","    delta_seq = hedger(inputs, training=False)[:, :, 0]\n","    delta_prev = tf.concat([tf.zeros((n, 1)), delta_seq[:, :-1]], axis=1)\n","\n","    price_changes = S[:, 1:n_steps+1] - S_seq\n","    transaction_costs = tf.abs(delta_seq - delta_prev) * S_seq * fee\n","    pnl = tf.reduce_sum(delta_seq * price_changes - transaction_costs, axis=1, keepdims=True)\n","    pnl -= tf.maximum(S[:, -1:] - K, 0.0)\n","    return pnl.numpy().flatten(), delta_seq.numpy()\n","\n","\n","# Black-Scholes P&L\n","def pnl_bs(test_data, n_steps, K, fee, sigma, r=0.0):\n","    S = test_data.astype(\"float32\")\n","    n = S.shape[0]\n","    S_seq = S[:, :n_steps]\n","\n","    # annualized time to maturity\n","    tau = np.array([(n_steps - t) / 252.0 for t in range(n_steps)])[np.newaxis, :]\n","    delta = bs_delta(S_seq, K, tau, r, sigma)\n","    delta_prev = np.hstack([np.zeros((n, 1)), delta[:, :-1]])\n","\n","    price_changes = S[:, 1:n_steps+1] - S_seq\n","    transaction_costs = np.abs(delta - delta_prev) * S_seq * fee\n","    pnl = np.sum(delta * price_changes - transaction_costs, axis=1, keepdims=True)\n","    pnl -= np.maximum(S[:, -1:] - K, 0.0)\n","    return pnl.flatten(), delta\n","\n","\n","# summary metrics for one P&L distribution\n","def metrics(pnl, risk_aversion, deltas):\n","\n","    # 95% Expected Shortfall: average of the worst 5% of outcomes\n","    pnl_sorted = np.sort(pnl)\n","    worst_5pct = pnl_sorted[:max(1, int(0.05 * len(pnl_sorted)))]\n","\n","    # turnover: how much we trade over the whole path\n","    delta_prev = np.concatenate([np.zeros((deltas.shape[0], 1)), deltas[:, :-1]], axis=1)\n","    turnover = np.mean(np.sum(np.abs(deltas - delta_prev), axis=1))\n","\n","    return {\n","        \"mean\":     float(np.mean(pnl)),\n","        \"std\":      float(np.std(pnl)),\n","        \"entropic\": float(entropic_loss(pnl, risk_aversion).numpy()),\n","        \"cvar95\":   float(-np.mean(worst_5pct)),\n","        \"turnover\": float(turnover),\n","    }\n","\n","\n","# train both hedgers and score all three under one configuration\n","def run_config(train_data, test_data, n_steps=30, K=1.0, fee=1e-3,\n","               risk_aversion=10, sigma=0.2, epochs=sweep_epochs):\n","\n","    mlp = train_mlp(train_data, n_steps, K, fee, risk_aversion, epochs)\n","    gru = train_gru(train_data, n_steps, K, fee, risk_aversion, epochs)\n","\n","    mlp_pnl, mlp_delta = pnl_mlp(mlp, test_data, n_steps, K, fee)\n","    gru_pnl, gru_delta = pnl_gru(gru, test_data, n_steps, K, fee)\n","    bs_pnl,  bs_delta  = pnl_bs(test_data, n_steps, K, fee, sigma)\n","\n","    rows = []\n","    for name, pnl, delta in [(\"MLP\", mlp_pnl, mlp_delta),\n","                             (\"GRU\", gru_pnl, gru_delta),\n","                             (\"BS\",  bs_pnl,  bs_delta)]:\n","        row = metrics(pnl, risk_aversion, delta)\n","        row[\"model\"] = name\n","        rows.append(row)\n","\n","    return rows"],"metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-03T17:29:48.42083Z","iopub.execute_input":"2026-06-03T17:29:48.42118Z","iopub.status.idle":"2026-06-03T17:29:48.44153Z","shell.execute_reply.started":"2026-06-03T17:29:48.421147Z","shell.execute_reply":"2026-06-03T17:29:48.440446Z"},"id":"XiQkD8AnlWqQ","executionInfo":{"status":"ok","timestamp":1780522321937,"user_tz":-120,"elapsed":7,"user":{"displayName":"Riccardo Ravelli","userId":"15250967032132411123"}}},"outputs":[],"execution_count":26},{"cell_type":"markdown","source":["### 6.3 — Transaction cost\n","\n","The cost enters both training and evaluation, so the networks are re-trained at every level.\n"],"metadata":{"id":"BbEHZAr_lWqR"}},{"cell_type":"code","source":["# re-train at every fee level\n","fees = [0.0, 0.0005, 0.001, 0.005]\n","records = []\n","\n","for fee in fees:\n","    rows = run_config(train, test, fee=fee)\n","    for row in rows:\n","        row[\"fee_bps\"] = fee * 1e4\n","        records.append(row)\n","\n","df_cost = pd.DataFrame(records)\n","display(df_cost.pivot_table(index=\"fee_bps\", columns=\"model\",\n","                            values=[\"entropic\", \"turnover\"]).round(5))\n","\n","# entropic loss vs cost\n","plt.figure(figsize=(9, 5))\n","for name, sub in df_cost.groupby(\"model\"):\n","    sub = sub.sort_values(\"fee_bps\")\n","    plt.plot(sub[\"fee_bps\"], sub[\"entropic\"], marker=\"o\", label=name)\n","plt.xlabel(\"transaction cost (bps)\")\n","plt.ylabel(\"entropic loss\")\n","plt.title(\"Entropic loss vs transaction cost\")\n","plt.legend()\n","plt.grid(alpha=0.3)\n","plt.show()"],"metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-03T17:29:48.442608Z","iopub.execute_input":"2026-06-03T17:29:48.443007Z","iopub.status.idle":"2026-06-03T17:31:02.214709Z","shell.execute_reply.started":"2026-06-03T17:29:48.442948Z","shell.execute_reply":"2026-06-03T17:31:02.213741Z"},"id":"z7Z3WTchlWqR","colab":{"base_uri":"https://localhost:8080/","height":713},"executionInfo":{"status":"ok","timestamp":1780522431654,"user_tz":-120,"elapsed":109721,"user":{"displayName":"Riccardo Ravelli","userId":"15250967032132411123"}},"outputId":"6991e930-d3c6-4086-a607-8f8c8d2a86f5"},"outputs":[{"output_type":"display_data","data":{"text/plain":["        entropic                   turnover                  \n","model         BS      GRU      MLP       BS      GRU      MLP\n","fee_bps                                                      \n","0.0      0.02541  0.02375  0.02317  2.02184  1.29645  1.10966\n","5.0      0.02644  0.02427  0.02386  2.02184  1.08839  1.05449\n","10.0     0.02747  0.02477  0.02455  2.02184  0.99193  0.95272\n","50.0     0.03576  0.02823  0.02812  2.02184  0.71459  0.53884"],"text/html":["\n","  <div id=\"df-5c173d0d-6090-4246-9e01-251c7dbf19a1\" class=\"colab-df-contai