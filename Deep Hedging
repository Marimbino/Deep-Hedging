00%***********************]  1 of 1 completed\n"]}],"execution_count":18},{"cell_type":"code","source":["# MLP: sequential, delta feeds back into the input\n","mlp_deltas = []\n","d_prev = tf.zeros((1, 1))\n","for t in range(num_steps):\n","    S_today = path[:, t:t+1]\n","    tau_t   = tf.fill((1, 1), (num_steps - t) / num_steps)\n","    state   = tf.concat([d_prev, S_today, tau_t], axis=1)\n","    d_new   = hedger_mlp(state, training=False)\n","    mlp_deltas.append(float(d_new.numpy().flatten()[0]))\n","    d_prev  = d_new\n","mlp_deltas = np.array(mlp_deltas)\n","\n","# 2) GRU: one forward pass over the whole path\n","S_seq_1  = path[:, :num_steps]\n","tau_1    = tf.broadcast_to(tau_seq, tf.shape(S_seq_1))\n","inputs_1 = tf.stack([S_seq_1, tau_1], axis=-1)\n","gru_deltas = hedger_gru(inputs_1, training=False)[0, :, 0].numpy()\n","\n","# 3) Black-Scholes delta\n","tau_bs_1   = np.array([(num_steps - t) / 252.0 for t in range(num_steps)])\n","bs_deltas  = bs_delta(path_np[:num_steps], K, tau_bs_1, r, sigma)\n","\n","# trades = day-to-day change in holding (delta_t - delta_{t-1})\n","def to_trades(deltas):\n","    prev = np.concatenate([[0.0], deltas[:-1]])\n","    return deltas - prev\n","\n","mlp_trades = to_trades(mlp_deltas)\n","gru_trades = to_trades(gru_deltas)\n","bs_trades  = to_trades(bs_deltas)\n","\n","# assemble a tidy day-by-day table\n","df_days = pd.DataFrame({\n","    \"day\":        np.arange(num_steps),\n","    \"S_t\":        path_np[:num_steps].round(4),\n","    \"MLP_delta\":  mlp_deltas.round(4),\n","    \"MLP_trade\":  mlp_trades.round(4),\n","    \"GRU_delta\":  gru_deltas.round(4),\n","    \"GRU_trade\":  gru_trades.round(4),\n","    \"BS_delta\":   bs_deltas.round(4),\n","    \"BS_trade\":   bs_trades.round(4),\n","})\n","\n","final_price = path_np[-1]\n","payoff_1    = max(final_price - K, 0.0)\n","print(f\"Path last 30 trading days:  S_0 = {path_np[0]:.4f}   S_T = {path_np[30]:.4f}   \")\n","print(df_days.to_string(index=False))"],"metad